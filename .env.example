PORT=3000
NODE_ENV=production
DATABASE_URL="postgresql://user:password@host:5432/dbname"

JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Cashfree
CASHFREE_CLIENT_ID=""
CASHFREE_CLIENT_SECRET=""
CASHFREE_ENV=SANDBOX
CASHFREE_API_VERSION=2025-01-01
CASHFREE_RETURN_URL="https://yourdomain.com/payment/return"

# IMPORTANT: Configure webhook in Cashfree dashboard
# Webhook URL: https://yourdomain.com/api/partner/confirm-order-wb
# Events: PAYMENT_SUCCESS_WEBHOOK, PAYMENT_FAILED_WEBHOOK, PAYMENT_USER_DROPPED_WEBHOOK
# Signature verification is MANDATORY and uses CASHFREE_CLIENT_SECRET

# Partner agreement PDF disk fallback (survives restart between e-sign and payment)
AGREEMENT_TEMP_DIR=./tmp/agreements

BASE_URL="https://yourdomain.com"

# Pratima custom file-storage engine (partner agreement PDFs)
PRATIMA_BASE_URL="https://pratima.homecarehelp.in"
PRATIMA_API_KEY=""
PRATIMA_COMPANY_ID=""

# Comma-separated list of allowed frontend origins for CORS
# Add your frontend and backend domains here
CORS_ORIGINS="https://homecarehelp.in,https://backend.homecarehelp.in"

# Set only if Puppeteer's bundled Chrome isn't available (e.g. system chromium on a VPS)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
